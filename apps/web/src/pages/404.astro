---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="404 — No encontrado">
  <Navbar />
  <main id="main-content" class="flex flex-col items-center justify-center min-h-screen px-6 text-center">
    <p class="font-mono text-sm text-accent-green mb-4">// 404</p>
    <h1 class="font-display text-4xl md:text-6xl font-bold italic text-fg mb-4">
      Página no encontrada
    </h1>
    <p class="font-body text-fg-secondary mb-8 max-w-md">
      La ruta que buscas no existe o fue movida. Vuelve al inicio para continuar navegando.
    </p>
    <a
      href="/"
      class="font-mono text-sm px-8 py-3 rounded-full bg-accent-green text-black hover:scale-105 transition-transform duration-300"
    >
      ← Volver al inicio
    </a>
  </main>
  <Footer />
</Layout>
