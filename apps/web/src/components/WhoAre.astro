---
/**
 * WhoAre — Sección "Quiénes somos"
 * Scroll-Driven gradient text fill animation (left to right), line by line
 */
---

<section id="whoare" data-theme="light" class="relative w-full py-40 md:py-48 px-6 md:px-16 bg-bg overflow-hidden">
  <div class="max-w-6xl mx-auto text-left md:text-center">
    <p class="font-mono text-accent-green text-sm mb-8">// whoare</p>
    
    <h2 class="font-display text-2xl md:text-4xl lg:text-5xl leading-relaxed mb-12">
      <span data-animate="text-fill" class="text-fill-reveal block">Fusionamos la</span>
      <span data-animate="text-fill" class="text-fill-reveal block font-bold italic text-accent-green tracking-tight">ingeniería de software</span>
      <span data-animate="text-fill" class="text-fill-reveal block">más moderna con la</span>
      <span data-animate="text-fill" class="text-fill-reveal block font-bold italic text-accent-green tracking-tight">dirección de arte contemporánea,</span>
      <span data-animate="text-fill" class="text-fill-reveal block">asegurando un ecosistema dígital</span>
      <span data-animate="text-fill" class="text-fill-reveal block">robusto, ágil y visualmente impecable.</span>
    </h2>

    <a href="/contacto" class="inline-flex items-center gap-3 bg-accent-lime text-terminal-black font-mono font-bold px-8 py-4 rounded-xl hover:scale-105 transition-transform duration-300" style="view-transition-name: hero-cta">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
      Trabajemos Juntos!
    </a>
  </div>
</section>

<style>
  :global(.text-fill-reveal) {
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-image: linear-gradient(
      to right,
      var(--color-fg) 0%,
      var(--color-fg) 100%
    );
    background-repeat: no-repeat;
    background-size: 0% 100%;
  }

  :root.dark :global(.text-fill-reveal) {
    background-image: linear-gradient(
      to right,
      var(--color-fg) 0%,
      var(--color-fg) 100%
    );
  }
</style>
