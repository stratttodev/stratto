---
/**
 * Teams — Sección de equipos
 * Píldoras animadas flotando alrededor del texto centrado
 */
---

<section id="teams" data-theme="light" class="relative w-full py-8 md:py-32 px-6 md:px-16 bg-bg overflow-hidden">
  <div class="max-w-6xl mx-auto relative min-h-125 flex flex-col items-center justify-center">
    <!-- Texto centrado -->
    <div class="text-center z-10">
      <p class="font-mono text-accent-green text-sm mb-8">// teams</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-fg leading-tight">
        Un equipo dedicado,<br>
        <span class="font-bold italic tracking-tight ">totalmente integrado.</span>
      </h2>
    </div>

    <!-- Píldoras flotantes -->
    <!-- Superior izquierda -->
    <div class="absolute top-[5%] left-[8%] md:left-[12%]">
      <span class="pill md:text-4xl md:px-8 md:py-4 bg-accent-green dark:bg-green-400 text-white dark:text-green-950 font-bold italic tracking-tighter">
        Diseño
      </span>
    </div>

    <!-- Superior derecha -->
    <div class="absolute top-[10%] right-[5%] md:right-[12%]">
      <span class="pill md:text-2xl md:px-8 md:py-4 bg-[#DFF4E0] dark:bg-green-100 text-green-900 dark:text-green-900 font-bold italic tracking-tighter">
        Gestión
      </span>
    </div>

    <!-- Media izquierda (más grande, saliendo del container) -->
    <div class="absolute top-1/2 -translate-y-1/2 left-[-40%] md:left-[-25%]">
      <span class="pill md:text-5xl md:px-10 md:py-5 bg-accent-lime dark:bg-lime-300 text-lime-900 dark:text-lime-900 font-bold italic tracking-tighter">
        Planificación
      </span>
    </div>

    <!-- Media derecha (más grande, saliendo del container) -->
    <div class="absolute top-1/2 -translate-y-1/2 right-[-40%] md:right-[-25%]">
      <span class="pill md:text-5xl md:px-10 md:py-5 bg-rose-400 dark:bg-rose-300 text-white dark:text-rose-950 font-bold italic tracking-tighter">
        Implementación
      </span>
    </div>

    <!-- Inferior izquierda -->
    <div class="absolute bottom-[10%] left-[5%] md:left-[12%]">
      <span class="pill md:text-2xl md:px-8 md:py-4 bg-orange-400 dark:bg-orange-300 text-white dark:text-orange-950 font-bold italic tracking-tighter">
        Ingeniería
      </span>
    </div>

    <!-- Inferior derecha -->
    <div class="absolute bottom-[5%] right-[8%] md:right-[12%]">
      <span class="pill md:text-2xl md:px-8 md:py-4 bg-violet-400 dark:bg-violet-300 text-white dark:text-violet-950 font-bold italic tracking-tighter">
        Desarrollo
      </span>
    </div>
  </div>
</section>

<style>
  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-family: var(--font-display);
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .pill-sm {
    font-size: 0.875rem;
    padding: 0.5rem 1.25rem;
  }

  .pill-md {
    font-size: 1.125rem;
    padding: 0.75rem 1.75rem;
  }

  .pill-lg {
    font-size: 1.125rem;
    padding: 0.75rem 1.75rem;
  }

  .pill-xl {
    font-size: 2rem;
    padding: 1.25rem 2.75rem;
  }

  /* Profundidad: scale + blur */
  .pill-depth-1 {
    transform: scale(0.9);
    filter: blur(1px);
    opacity: 0.8;
  }

  .pill-depth-2 {
    transform: scale(1);
    filter: blur(0);
    opacity: 1;
  }

  .pill-depth-3 {
    transform: scale(1.1);
    filter: blur(0);
    opacity: 1;
  }
</style>
