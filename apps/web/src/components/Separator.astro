---
/**
 * Separator — Separador con texto animado en scroll
 * Animación: traslación en eje X al hacer scroll
 */
---

<div class="relative w-full py-16 px-6 md:px-16 overflow-hidden" data-theme="light"  aria-hidden="true">
  <div class="max-w-6xl mx-auto flex flex-col gap-4 items-center text-center">
    <p class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-7xl text-accent-green dark:text-white whitespace-nowrap md:whitespace-nowrap separator-line-1">
      <span class="font-bold italic tracking-tight">Codificamos</span> el futuro <span class="font-mono text-accent-green/60 dark:text-white/60">//</span>
    </p>
    <p class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-7xl text-accent-green dark:text-white whitespace-nowrap md:whitespace-nowrap separator-line-2">
      <span class="font-mono text-accent-green/60 dark:text-white/60">//</span> <span class="font-bold italic tracking-tight">Simplificamos</span> problemas <span class="font-mono text-accent-green/60 dark:text-white/60">_</span>
    </p>
  </div>
</div>

<style>
  /* Placeholder - animación con GSAP ScrollTrigger después */
  .separator-line-1,
  .separator-line-2 {
    opacity: 1;
  }
</style>
