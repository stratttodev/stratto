---
/**
 * Separator — Separador con texto animado en scroll
 * Animación: gradient text fill left to right
 */
---

<div class="relative w-full py-20 px-6 md:px-16 overflow-hidden" data-theme="light" aria-hidden="true">
  <div class="max-w-6xl mx-auto flex flex-col gap-4 items-center text-center">
    <p class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-7xl whitespace-nowrap">
      <span data-animate="text-fill" class="text-fill-reveal font-bold italic tracking-tight">Codificamos</span>
      <span data-animate="text-fill" class="text-fill-reveal">el</span>
      <span data-animate="text-fill" class="text-fill-reveal font-bold italic tracking-tight">futuro</span>
      <span data-animate="text-fill" class="text-fill-reveal font-mono text-accent-green/60 dark:text-white/60">//</span>
    </p>
    <p class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-7xl whitespace-nowrap">
      <span data-animate="text-fill" class="text-fill-reveal font-mono text-accent-green/60 dark:text-white/60">//</span>
      <span data-animate="text-fill" class="text-fill-reveal font-bold italic tracking-tight">Simplificamos</span>
      <span data-animate="text-fill" class="text-fill-reveal">problemas</span>
      <span data-animate="text-fill" class="text-fill-reveal font-mono text-accent-green/60 dark:text-white/60">_</span>
    </p>
  </div>
</div>

<style>
  .text-fill-reveal {
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-image: linear-gradient(
      to right,
      var(--color-accent-green) 0%,
      var(--color-accent-green) 100%
    );
    background-repeat: no-repeat;
    background-size: 0% 100%;
  }

  :root.dark .text-fill-reveal {
    background-image: linear-gradient(
      to right,
      white 0%,
      white 100%
    );
  }
</style>
