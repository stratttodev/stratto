---
/**
 * Navbar — Barra de navegación global
 * Navbar = contenedor flotante sin bg
 * NavbarInner = tiene bg overlay que se desvanece suavemente
 */
import Isotype from "../icons/Isotype.astro";
import LetterLogo from "../icons/letterLogo.astro";
import Menu from "../icons/Menu.astro";
import MenuPlus from "../icons/MenuPlus.astro";
import Moon from "../icons/Moon.astro";
import Sun from "../icons/Sun.astro";

const navLinks = [
  { label: "Inicio", href: "#header" },
  { label: "Stratto", href: "#whoare" },
  { label: "Servicios", href: "#services" },
  { label: "Tema", href: "#teams" },
  { label: "Collab", href: "#collab" },
  { label: "Tecnología", href: "#tech" },
];
---

<div id="navbar" class="fixed top-0 left-0 w-full z-50 mt-4 md:mt-6 pointer-events-none">
  <nav
    id="navbar-inner"
    class="relative mx-auto flex items-center justify-between font-mono text-2xl px-8 py-6 md:px-16 md:py-8 pointer-events-auto overflow-hidden transition-[max-width,border-radius] duration-700 ease-in-out"
  >
    <!-- Background overlay -->
    <div
      id="navbar-bg"
      class="absolute inset-0 rounded-xl transition-all duration-700 ease-in-out opacity-0 backdrop-blur-md"
    ></div>

    <!-- Content -->
    <div class="relative z-10 flex items-center justify-between w-full">
      <!-- Left: Isotype + Logo -->
      <div class="flex items-center gap-3">
        <Isotype class="w-6 h-6" />
        <LetterLogo class="h-5 w-auto" />
      </div>

      <!-- Center: Nav Links (hidden by default, shown when menu open) -->
      <nav
        id="nav-links"
        class="hidden md:flex items-center gap-8 font-mono text-xs opacity-0 pointer-events-none -translate-y-2.5 transition-all duration-300"
      >
        {navLinks.map(({ label, href }) => (
          <a
            href={href}
            class="nav-link text-fg-secondary hover:text-fg hover:scale-110 transition-all duration-300"
            data-nav-link
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Right: Icons + /labs -->
      <div class="flex items-center gap-5">
        <button id="menu-toggle" class="cursor-pointer relative w-5 h-5" aria-label="Toggle menu">
          <span id="icon-menu-plus" class="absolute inset-0 transition-all duration-300 ease-in-out"><MenuPlus class="cursor-pointer w-5 h-5" /></span>
          <span id="icon-menu" class="absolute inset-0 transition-all duration-300 ease-in-out opacity-0 scale-50"><Menu class="cursor-pointer w-5 h-5" /></span>
        </button>
        <span class="font-display italic font-bold text-sm">us</span>
        <button id="theme-toggle" class="cursor-pointer relative w-5 h-5" aria-label="Toggle dark mode">
          <span id="icon-moon" class="absolute inset-0 transition-all duration-300 ease-in-out"><Moon class="cursor-pointer" /></span>
          <span id="icon-sun" class="absolute inset-0 transition-all duration-300 ease-in-out opacity-0 scale-50"><Sun class="cursor-pointer" /></span>
        </button>
        <span class="font-display italic font-bold text-sm hidden md:inline">/labs</span>
      </div>
    </div>
  </nav>
</div>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 z-40 flex items-center justify-center bg-bg/95 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500 ease-in-out"
>
  <nav class="flex flex-col items-center gap-10">
    {navLinks.map(({ label, href }, index) => (
      <a
        href={href}
        class="mobile-nav-link font-display text-5xl text-fg hover:text-accent-green hover:scale-110 transition-all duration-300 translate-y-8 opacity-0"
        style={`transition-delay: ${index * 75}ms`}
      >
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const navbarInner = document.getElementById("navbar-inner");
  const navbarBg = document.getElementById("navbar-bg");
  const toggleBtn = document.getElementById("theme-toggle");
  const menuToggle = document.getElementById("menu-toggle");
  const navLinks = document.getElementById("nav-links");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");
  const iconMoon = document.getElementById("icon-moon");
  const iconSun = document.getElementById("icon-sun");
  const iconMenuPlus = document.getElementById("icon-menu-plus");
  const iconMenu = document.getElementById("icon-menu");
  const html = document.documentElement;

  let isMenuOpen = false;

  const bgColors = {
    dark: "bg-terminal-black",
    light: "bg-white",
  };

  const textColors = {
    dark: "text-pixel-clean",
    light: "text-[#1a1a1a]",
  };

  const iconColors = {
    moon: "text-sky-400",
    sun: "text-amber-400",
  };

  let currentAppliedTheme: "dark" | "light" | "reset" = "reset";
  let isDarkMode = html.classList.contains("dark");

  function updateSvgClasses(el: SVGElement, classes: string[]) {
    const current = el.getAttribute("class") || "";
    const cleaned = current.replace(/text-\S+/g, "").trim();
    el.setAttribute("class", [...cleaned.split(/\s+/), ...classes].join(" "));
  }

  function updateIcons(mode: "dark" | "light") {
    const moonIcon = iconMoon?.querySelector("svg") as SVGElement | null;
    const sunIcon = iconSun?.querySelector("svg") as SVGElement | null;
    const menuIcon = navbarInner?.querySelector("svg:first-of-type") as SVGElement | null;
    const isotypeIcon = navbarInner?.querySelector("[class*='w-6']") as SVGElement | null;
    const letterLogo = navbarInner?.querySelector("[class*='h-5']") as SVGElement | null;

    [menuIcon, isotypeIcon, letterLogo].forEach((el) => {
      if (el) updateSvgClasses(el, [textColors[mode]]);
    });

    if (moonIcon) updateSvgClasses(moonIcon, [iconColors.moon]);
    if (sunIcon) updateSvgClasses(sunIcon, [iconColors.sun]);
  }

  function updateTextSpans(mode: "dark" | "light") {
    if (!navbarInner) return;
    const spans = navbarInner.querySelectorAll("span");
    spans.forEach((span) => {
      if (span.classList.contains("font-display")) {
        span.className = span.className.replace(/text-\S+/g, "");
        span.classList.add(textColors[mode]);
      }
    });
    // Update nav links color
    const navLinksEls = document.querySelectorAll("[data-nav-link]");
    navLinksEls.forEach((el) => {
      el.className = el.className.replace(/text-\S+/g, "");
      el.classList.add(textColors[mode]);
    });
  }

  function applyNavbarStyle(sectionTheme: "dark" | "light") {
    if (!navbarInner || !navbarBg) return;

    const navbarMode = isDarkMode ? "light" : (sectionTheme === "light" ? "dark" : "light");

    if (currentAppliedTheme === sectionTheme && !isDarkMode) return;
    currentAppliedTheme = sectionTheme;

    navbarBg.classList.remove("opacity-0");
    navbarBg.classList.add("opacity-100");
    navbarBg.className = navbarBg.className.replace(/bg-\S+/g, "");
    navbarBg.classList.add(bgColors[navbarMode]);

    navbarInner.className = navbarInner.className.replace(/text-\S+/g, "");
    navbarInner.classList.add(textColors[navbarMode]);

    updateIcons(navbarMode);
    updateTextSpans(navbarMode);
  }

  function resetNavbar() {
    if (!navbarInner || !navbarBg) return;

    currentAppliedTheme = "reset";

    navbarBg.classList.remove("opacity-100");
    navbarBg.classList.add("opacity-0");

    navbarInner.className = navbarInner.className.replace(/text-\S+/g, "");
    navbarInner.classList.add("text-pixel-clean");

    updateIcons("dark");
    updateTextSpans("dark");
  }

  function updateToggleIcon() {
    if (isDarkMode) {
      iconMoon?.classList.add("opacity-0", "scale-50");
      iconMoon?.classList.remove("opacity-100", "scale-100");
      iconSun?.classList.remove("opacity-0", "scale-50");
      iconSun?.classList.add("opacity-100", "scale-100");
    } else {
      iconMoon?.classList.remove("opacity-0", "scale-50");
      iconMoon?.classList.add("opacity-100", "scale-100");
      iconSun?.classList.add("opacity-0", "scale-50");
      iconSun?.classList.remove("opacity-100", "scale-100");
    }
  }

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;

    // Swap icons: open = Menu, closed = MenuPlus
    if (iconMenuPlus && iconMenu) {
      if (isMenuOpen) {
        iconMenuPlus.classList.add("opacity-0", "scale-50");
        iconMenuPlus.classList.remove("opacity-100", "scale-100");
        iconMenu.classList.remove("opacity-0", "scale-50");
        iconMenu.classList.add("opacity-100", "scale-100");
      } else {
        iconMenuPlus.classList.remove("opacity-0", "scale-50");
        iconMenuPlus.classList.add("opacity-100", "scale-100");
        iconMenu.classList.add("opacity-0", "scale-50");
        iconMenu.classList.remove("opacity-100", "scale-100");
      }
    }

    // Desktop: inline links
    if (navLinks) {
      if (isMenuOpen) {
        navLinks.classList.remove("opacity-0", "pointer-events-none", "-translate-y-2.5");
        navLinks.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
      } else {
        navLinks.classList.add("opacity-0", "pointer-events-none", "-translate-y-2.5");
        navLinks.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
      }
    }

    // Mobile: overlay menu
    if (mobileMenu) {
      if (isMenuOpen) {
        mobileMenu.classList.remove("opacity-0", "pointer-events-none");
        mobileMenu.classList.add("opacity-100", "pointer-events-auto");
        mobileNavLinks.forEach((link) => {
          link.classList.remove("translate-y-8", "opacity-0");
          link.classList.add("translate-y-0", "opacity-100");
        });
      } else {
        mobileMenu.classList.add("opacity-0", "pointer-events-none");
        mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
        mobileNavLinks.forEach((link) => {
          link.classList.add("translate-y-8", "opacity-0");
          link.classList.remove("translate-y-0", "opacity-100");
        });
      }
    }
  }

  const SCROLL_THRESHOLD = 1;

  function getCurrentSectionTheme(): "dark" | "light" {
    const sections = document.querySelectorAll("[data-theme]");
    const navbarHeight = 100;

    for (const section of sections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= navbarHeight && rect.bottom > navbarHeight) {
        return section.getAttribute("data-theme") as "dark" | "light";
      }
    }

    const first = sections[0];
    if (first) {
      return first.getAttribute("data-theme") as "dark" | "light";
    }
    return "dark";
  }

  function updateScrollState() {
    if (!navbarInner) return;
    const scrolled = window.scrollY > SCROLL_THRESHOLD;
    const isMd = window.innerWidth >= 768;
    const margin = isMd ? "1.5rem" : "1rem";

    if (scrolled) {
      navbarInner.style.maxWidth = "64rem";
      navbarInner.style.margin = `${margin} auto`;
      navbarInner.classList.add("rounded-xl");

      const theme = getCurrentSectionTheme();
      applyNavbarStyle(theme);
    } else {
      navbarInner.style.maxWidth = "100%";
      navbarInner.style.margin = "";
      navbarInner.classList.remove("rounded-xl");

      resetNavbar();
    }
  }

  window.addEventListener("scroll", updateScrollState, { passive: true });

  menuToggle?.addEventListener("click", toggleMenu);

  navLinks?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  toggleBtn?.addEventListener("click", () => {
    isDarkMode = !isDarkMode;
    html.classList.toggle("dark", isDarkMode);
    updateToggleIcon();

    const scrolled = window.scrollY > SCROLL_THRESHOLD;
    if (scrolled) {
      currentAppliedTheme = "reset";
      const theme = getCurrentSectionTheme();
      applyNavbarStyle(theme);
    }
  });

  updateToggleIcon();
  resetNavbar();
  updateScrollState();
</script>
