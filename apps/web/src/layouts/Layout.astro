---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

import "@fontsource/lilex/400.css";
import "@fontsource/lilex/500.css";
import "@fontsource/lilex/700.css";
import "@fontsource/lilex/400-italic.css";
import "@fontsource/cascadia-code/400.css";
import "@fontsource/cascadia-code/600.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "STRATTO — laboratorio de tecnología, desarrollo de software y diseño de interfaces.",
  canonical,
} = Astro.props;

const resolvedCanonical = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/ogImage.png", Astro.site).href;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={resolvedCanonical} />
    <title>{title} · STRATTO</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={`${title} · STRATTO`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Stratto" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · STRATTO`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Stratto",
      url: "https://stratto.dev",
      logo: new URL("/favicon.svg", Astro.site).href,
      description,
      sameAs: [
        "https://linkedin.com",
        "https://instagram.com",
        "https://github.com",
      ],
      contactPoint: {
        "@type": "ContactPoint",
        email: "hello@stratto.dev",
        contactType: "customer service",
      },
    })} />

    <script is:inline>
      (function() {
        var t = localStorage.getItem('stratto-theme');
        if (t === 'light') document.documentElement.classList.remove('dark');
        else document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="bg-bg text-fg font-body antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:bg-accent-green focus:text-black focus:px-4 focus:py-2 focus:rounded-lg focus:font-mono focus:text-sm">
      Saltar al contenido principal
    </a>
    <slot />
    <Analytics />
    <SpeedInsights />
    <script>
      import { initScrollAnimations } from "../scripts/scroll-animations";
      document.addEventListener("DOMContentLoaded", initScrollAnimations);
    </script>
  </body>
</html>
